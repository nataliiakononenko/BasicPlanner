<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Header row with week number column -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            
            <!-- Empty space for week number column -->
            <View
                android:layout_width="24dp"
                android:layout_height="wrap_content" />
            
            <LinearLayout
                android:id="@+id/weekday_headers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Calendar grid with week numbers -->
        <LinearLayout
            android:id="@+id/month_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly Goals"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:padding="16dp"
            android:paddingTop="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_month_todos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/tv_no_month_todos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No monthly goals"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>
